# Finnhub
# Get from: https://finnhub.io/dashboard
# Browser-visible fallback key for local dev and simple deployments
VITE_FINNHUB_API_KEY=your_finnhub_key_here
# Preferred server-side key for API routes and newsletter jobs
FINNHUB_API_KEY=your_finnhub_server_key_here

# Supabase browser auth
# Get from: https://supabase.com -> Project Settings -> API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase server access
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Stripe billing
# Get from: https://dashboard.stripe.com/apikeys and your product pricing pages
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_MONTHLY=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ANNUAL=price_xxxxxxxxxxxxxxxxxxxx

# Resend
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Newsletter config
# Use onboarding@resend.dev for testing or a verified domain in production
NEWSLETTER_FROM=Nuclear Pulse <newsletter@yourdomain.com>

# Deployed site URL used for billing/auth redirect fallbacks.
# In production this must be your real public host, not localhost.
SITE_URL=https://your-site.vercel.app

# Comma-separated browser origins allowed to call API routes
ALLOWED_ORIGINS=https://your-site.vercel.app,http://localhost:5173

# Secret used to sign unsubscribe links
UNSUBSCRIBE_SECRET=replace_with_a_long_random_secret

# SEC EDGAR requests should use a descriptive user agent with contact info
SEC_USER_AGENT=NuclearPulseBot admin@example.com

# Optional operator token for forcing terminal snapshot refresh
TERMINAL_REVALIDATE_TOKEN=replace_with_a_long_random_secret

# Optional table overrides
BILLING_MEMBERSHIPS_TABLE=billing_memberships
STRIPE_WEBHOOK_EVENTS_TABLE=stripe_webhook_events
TERMINAL_CACHE_TABLE=terminal_cache
